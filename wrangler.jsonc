{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "pulse-web",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // D1 Database
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pulse-web-db",
      "database_id": "4b3e7b18-c7b7-475f-8e0d-ae274b680a2f"
    }
  ]
}
